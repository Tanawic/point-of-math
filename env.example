# Copy to .env.local and fill in your keys
#
# ── Stripe ─────────────────────────────────────────────────
# dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# dashboard.stripe.com/webhooks  →  add endpoint: https://pointofmath.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
#
# ── Resend (email to student) ───────────────────────────────
# resend.com/api-keys  (free: 3000 emails/month)
RESEND_API_KEY=re_...
EMAIL_FROM=Point of Math <hello@pointofmath.com>
#
# ── Telegram (notification to you) ─────────────────────────
# Same values as quant_agent .env
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
#
# ── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://pointofmath.com
